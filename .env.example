# Database (use one of the two options)

# Option 1: Single connection string (recommended)
# Local (Docker): postgres://robotics:robotics@localhost:5432/robotics
# Hostinger: get from control panel → Databases → connection string
DATABASE_URL=postgres://robotics:robotics@localhost:5432/robotics

# Option 2: Separate vars (optional; app uses DATABASE_URL if set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=robotics
# DB_USER=robotics
# DB_PASS=robotics

# Session signing secret — REQUIRED in production (min 32 chars random string)
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Server (production). Next.js uses process.env.PORT automatically.
# PORT=3000
