# ──────────────────────────────────────────────────────────────────────────────
# Production environment variables — copy to .env.production and fill in values
# NEVER commit .env.production to git
# ──────────────────────────────────────────────────────────────────────────────

# Database credentials (used by docker-compose.production.yml)
DB_USER=robotics
DB_PASS=CHANGE_ME_STRONG_PASSWORD
DB_NAME=robotics
DB_PORT=5432

# Direct DB URLs (if not using compose internal networking)
DATABASE_URL=postgresql://robotics:CHANGE_ME_STRONG_PASSWORD@localhost:5432/robotics
MASTER_DATABASE_URL=postgresql://robotics:CHANGE_ME_STRONG_PASSWORD@localhost:5432/robotics

# Session secret — generate with: openssl rand -hex 64
SESSION_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET

# Base domain for subdomain-based tenant routing
# Example: if your app runs at robotics.example.com, set BASE_DOMAIN=example.com
BASE_DOMAIN=yourdomain.com

# Default dev center ID (leave empty in production)
DEFAULT_DEV_CENTER=

# Backup directory inside the container
BACKUP_DIR=/app/backups

# Next.js
NODE_ENV=production
PORT=9030
